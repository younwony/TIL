flowchart TB
    subgraph Plugin["Plugin Bundle (파일 기반)"]
        direction TB
        Meta["plugin.yaml<br/>메타데이터"]

        subgraph SkillsLayer["Skills (스킬)"]
            direction LR
            S1["역할별 지식<br/>YAML + Markdown"]
            S2["문서 생성 능력<br/>XLSX, PPTX, DOCX"]
            S3["프로세스 정의<br/>업무 절차"]
        end

        subgraph ConnectorLayer["Connectors (커넥터)"]
            direction LR
            C1["CRM 연결"]
            C2["지식 기반 연결"]
            C3["데이터 소스 연결"]
        end

        subgraph SlashLayer["Slash Commands (명령어)"]
            direction LR
            SC1["/report<br/>보고서 생성"]
            SC2["/analyze<br/>데이터 분석"]
            SC3["/review<br/>문서 검토"]
        end

        subgraph SubAgentLayer["Sub-agents (하위 에이전트)"]
