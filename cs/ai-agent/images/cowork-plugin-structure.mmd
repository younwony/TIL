    subgraph CrossPlatform["크로스 플랫폼 호환"]
        direction LR
        CP1["Claude Cowork"]
        CP2["VS Code / Copilot"]
        CP3["OpenAI Codex CLI"]
        CP4["Cursor / Goose / Amp"]
    end

    Meta --> SkillsLayer
    Meta --> ConnectorLayer
    Meta --> SlashLayer
    Meta --> SubAgentLayer
    SkillsLayer --> CrossPlatform

